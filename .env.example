# SSO municipal — patrón Plataforma Digital (similar a Miraflores)
NEXT_PUBLIC_SSO_ISSUER_URL=https://sso.lamolina.gob.pe
NEXT_PUBLIC_SSO_CLIENT_ID=munimol-portal
NEXT_PUBLIC_SSO_LOGIN_URL=/api/auth/login
NEXT_PUBLIC_SSO_LOGOUT_URL=/api/auth/logout
NEXT_PUBLIC_SSO_CALLBACK_URL=/api/auth/callback

# CMS interno (login oculto /panel)
# Secreto para firmar la cookie de sesión del panel
CMS_AUTH_SECRET=cambia-este-secreto-en-produccion
# Contraseña inicial del usuario admin (solo se usa al crear users.json)
CMS_ADMIN_PASSWORD=AdminMolina2026
